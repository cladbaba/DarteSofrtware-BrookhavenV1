-- [ OPTIMIZED ESP LOOP ]
RunService.RenderStepped:Connect(function()
    local camPos = Camera.CFrame.Position
    if States.ESP then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then 
                local char = p.Character
                local head = char:FindFirstChild("Head")
                if head then
                    local high = char:FindFirstChild("DarteHigh") 
                    if not high then
                        high = Instance.new("Highlight")
                        high.Name = "DarteHigh"
                        high.FillColor = Color3.fromRGB(0, 255, 150)
                        high.OutlineColor = Color3.new(1,1,1)
                        high.FillTransparency = 0.5
                        high.Parent = char
                    end
                    high.Enabled = true

                    local esp = head:FindFirstChild("DarteESP") 
                    if not esp then
                        esp = Instance.new("BillboardGui")
                        esp.Name = "DarteESP"
                        esp.AlwaysOnTop = true
                        esp.Size = UDim2.new(0, 150, 0, 50)
                        esp.StudsOffset = Vector3.new(0, 3, 0)
                        
                        local txt = Instance.new("TextLabel")
                        txt.Name = "Label"
                        txt.Size = UDim2.new(1,0,1,0)
                        txt.BackgroundTransparency = 1
                        txt.TextColor3 = Color3.new(1,1,1)
                        txt.Font = Enum.Font.GothamBold
                        txt.TextSize = 14
                        txt.TextStrokeTransparency = 0
                        txt.Parent = esp
                        esp.Parent = head
                    end
                    esp.Label.Text = p.DisplayName .. "\n[" .. math.floor((head.Position - camPos).Magnitude) .. "m]"
                end
            end
        end
    else
        for _, p in ipairs(Players:GetPlayers()) do
            if p.Character then
                local high = p.Character:FindFirstChild("DarteHigh")
                if high then high:Destroy() end
                local head = p.Character:FindFirstChild("Head")
                if head then
                    local esp = head:FindFirstChild("DarteESP")
                    if esp then esp:Destroy() end
                end
            end
        end
    end

    local hue = tick() % 3 / 3
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            if _G.VisualConfigs.RainbowPlayersEnabled then 
                ApplyRainbowToCharacter(player.Character, hue) 
            else 
                if next(_G.VisualConfigs.OriginalColors) then ResetPlayerColors(player.Character) end 
            end 
        end
    end
    
    if not _G.VisualConfigs.RainbowPlayersEnabled and next(_G.VisualConfigs.OriginalColors) then _G.VisualConfigs.OriginalColors = {} end
    
    if States.RainbowESP then
        local clr = Color3.fromHSV(hue, 1, 1)
        for _, pl in ipairs(Players:GetPlayers()) do 
            if pl ~= LocalPlayer and pl.Character then 
                local hl = pl.Character:FindFirstChild("DarteRainbowHigh")
                if not hl then
                    hl = Instance.new("Highlight")
                    hl.Name = "DarteRainbowHigh"
                    hl.FillTransparency = 0.5
                    hl.Parent = pl.Character
                end
                hl.FillColor = clr
                hl.OutlineColor = clr
                hl.Enabled = true
            end 
        end
    else
        for _, pl in ipairs(Players:GetPlayers()) do 
            if pl.Character then
                local hl = pl.Character:FindFirstChild("DarteRainbowHigh")
                if hl then hl:Destroy() end
            end
        end
    end
end)

RunService.Heartbeat:Connect(function()
    if States.GhostMode == true then
        local myChar = LocalPlayer.Character
        local myHrp = myChar and myChar:FindFirstChild("HumanoidRootPart")
        if myHrp then 
            for _, otherPlayer in ipairs(Players:GetPlayers()) do 
                if otherPlayer ~= LocalPlayer and otherPlayer.Character then 
                    local herHrp = otherPlayer.Character:FindFirstChild("HumanoidRootPart")
                    if herHrp and (myHrp.Position - herHrp.Position).Magnitude < 8 then 
                        myHrp.CFrame = myHrp.CFrame * CFrame.new(0, 2, 12) 
                    end 
                end 
            end 
        end
    end
end)

