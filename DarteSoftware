local function ResetPlayerColors(char)
    if not char then return end
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") or part:IsA("MeshPart") then 
            if _G.VisualConfigs.OriginalColors[part] then part.Color = _G.VisualConfigs.OriginalColors[part] end
        elseif part:IsA("CharacterMesh") or part:IsA("Clothing") or part:IsA("ShirtGraphic") then 
            part.Enabled = true 
        end
    end
end

local function ApplyRainbowToCharacter(char, hue)
    if not char then return end
    local rainbowColor = Color3.fromHSV(hue, 1, 1)
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") or part:IsA("MeshPart") then
            if not _G.VisualConfigs.OriginalColors[part] then _G.VisualConfigs.OriginalColors[part] = part.Color end
            part.Color = rainbowColor
            part.Material = Enum.Material.Neon
        elseif part:IsA("CharacterMesh") or part:IsA("Clothing") or part:IsA("ShirtGraphic") then 
            part.Enabled = false 
        end
    end
end

RunService.Stepped:Connect(function()
    local char = LocalPlayer.Character
    if not char then return end
    
    if States.Noclip then 
        for _, part in ipairs(char:GetChildren()) do 
            if part:IsA("BasePart") then part.CanCollide = false end 
        end 
    elseif States.SolidBody then 
        for _, v in ipairs(char:GetChildren()) do 
            if v:IsA("BasePart") then v.CanCollide = true; v.CollisionGroup = "Default" end 
        end
    else 
        for _, v in ipairs(char:GetChildren()) do 
            if v:IsA("BasePart") then v.CollisionGroup = "Players" end 
        end 
    end
    
    if States.SpinBot then
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then hrp.CFrame = hrp.CFrame * CFrame.Angles(0, math.rad(50), 0) end
    end
end)

