local function GetCart()
    local char = LocalPlayer.Character
    if not char then return nil end
    local tool = char:FindFirstChild("GroceryCart")
    if tool then return tool end
    local bp = LocalPlayer:FindFirstChild("Backpack")
    if bp then
        local cart = bp:FindFirstChild("GroceryCart")
        if cart then
            char:FindFirstChildOfClass("Humanoid"):EquipTool(cart)
            return cart
        end
    end
    return nil
end

-- Ana Kill Mantığı: Jitter ve Void Fix
local function AdvancedKillLogic(target)
    if not target or not target.Character or not target.Character:FindFirstChild("HumanoidRootPart") then return end
    local myChar = LocalPlayer.Character
    local myHrp = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myHrp then return end

    local cart = GetCart()
    local targetHrp = target.Character.HumanoidRootPart
    local startPos = myHrp.CFrame
    
    -- Noclip Aktif Et (Temasın kesilmemesi için)
    local nc = RunService.Stepped:Connect(function()
        if myChar then
            for _, v in pairs(myChar:GetDescendants()) do
                if v:IsA("BasePart") then v.CanCollide = false end
            end
        end
    end)

    -- Jitter ve Takip Döngüsü (1.5 Saniye)
    local killTime = tick()
    while tick() - killTime < 1.5 do
        if not target.Character or not targetHrp then break end
        
        -- Mikro Jitter: Koltuk tetikleyicisini zorlamak için saniyede 60 kez titreşim
        local jitter = Vector3.new(math.random(-1, 1)/10, 0, math.random(-1, 1)/10)
        
        -- Hedefin tam arkasında (0.7 stud mesafe) konumlan
        myHrp.CFrame = targetHrp.CFrame * CFrame.new(0, 0, 0.7) * CFrame.new(jitter)
        
        -- Hedef bindiyse beklemeden void'e geç
        if target.Character:FindFirstChildOfClass("Humanoid").Sit then break end
        
        RunService.RenderStepped:Wait()
    end

    -- VOID PAKETLEME (Hız ve Koordinat Kilidi)
    task.wait(0.1)
    myHrp.CFrame = CFrame.new(0, -49500, 0)
    myHrp.Velocity = Vector3.new(0, -50000, 0)
    
    task.wait(0.4)

    -- Temizlik ve Geri Dönüş
    nc:Disconnect()
    myHrp.Velocity = Vector3.new(0, 0, 0)
    myHrp.CFrame = startPos
end

