        SList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            Scroll.CanvasSize = UDim2.new(0, 0, 0, SList.AbsoluteContentSize.Y + 5)
        end)

        local open = false
        local DropObj = {}
        function DropObj:Refresh(newOpts)
            for _, v in pairs(Scroll:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
            for _, opt in pairs(newOpts) do
                local OptBtn = Instance.new("TextButton", Scroll)
                OptBtn.Size = UDim2.new(1, 0, 0, 25); OptBtn.BackgroundColor3 = Color3.fromRGB(30,30,30); OptBtn.Text = opt; OptBtn.TextColor3 = Color3.new(1,1,1); OptBtn.Font = Enum.Font.Gotham; OptBtn.TextSize = 12; Instance.new("UICorner", OptBtn).CornerRadius = UDim.new(0,4)
                OptBtn.MouseButton1Click:Connect(function() Lbl.Text = "   " .. text .. " : " .. opt; TweenService:Create(DFrame, TweenInfo.new(0.2), {Size = UDim2.new(1, -10, 0, 35)}):Play(); open = false; callback(opt) end)
            end
        end
        
        Btn.MouseButton1Click:Connect(function() 
            open = not open
            -- Limit dropdown height to 150px or content size to avoid going off-screen
            local targetSize = open and math.min(SList.AbsoluteContentSize.Y + 45, 180) or 35
            TweenService:Create(DFrame, TweenInfo.new(0.2), {Size = UDim2.new(1, -10, 0, targetSize)}):Play() 
        end)
        
        DropObj:Refresh(options)
        return DropObj
    end
    return TabElements
end

