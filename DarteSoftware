-- // 🚀 MOVEMENT \\
local MoveTab = DarteEngine:MakeTab("🚀 Movement")
local FlySpeed = 2
local FlyLoop; local FlyConn
local function ToggleFly()
    States.Fly = not States.Fly
    local Char = LocalPlayer.Character
    if not Char or not Char:FindFirstChild("HumanoidRootPart") then return end
    local HRP = Char.HumanoidRootPart
    local Hum = Char:FindFirstChildOfClass("Humanoid")
    if States.Fly then
        if Hum then Hum.PlatformStand = true end
        FlyLoop = RunService.Heartbeat:Connect(function()
            local Look = Camera.CFrame.LookVector; local Right = Camera.CFrame.RightVector; local Move = Vector3.new(0,0,0)
            if UIS:IsKeyDown(Enum.KeyCode.W) then Move = Move + Look end
            if UIS:IsKeyDown(Enum.KeyCode.S) then Move = Move - Look end
            if UIS:IsKeyDown(Enum.KeyCode.A) then Move = Move - Right end
            if UIS:IsKeyDown(Enum.KeyCode.D) then Move = Move + Right end
            if UIS:IsKeyDown(Enum.KeyCode.Space) then Move = Move + Vector3.new(0,1,0) end
            if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then Move = Move - Vector3.new(0,1,0) end
            if Move.Magnitude > 0 then Move = Move.Unit * FlySpeed end
            HRP.CFrame = HRP.CFrame + Move; HRP.Velocity = Vector3.new(0,0,0) 
        end)
    else
        if FlyLoop then FlyLoop:Disconnect() end
        if Hum then Hum.PlatformStand = false end
    end
end
if FlyConn then FlyConn:Disconnect() end
FlyConn = UIS.InputBegan:Connect(function(input, proc) if not proc and input.KeyCode == Enum.KeyCode.E then ToggleFly() end end)

