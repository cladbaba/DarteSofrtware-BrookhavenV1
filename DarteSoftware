local function ResetPlayerColors(char)
    if not char then return end
    for _, part in pairs(char:GetDescendants()) do
        if part:IsA("BasePart") or part:IsA("MeshPart") then if _G.VisualConfigs.OriginalColors[part] then part.Color = _G.VisualConfigs.OriginalColors[part] end
        elseif part:IsA("CharacterMesh") or part:IsA("Clothing") or part:IsA("ShirtGraphic") then part.Enabled = true end
    end
end

local function ApplyRainbowToCharacter(char, hue)
    if not char then return end
    local rainbowColor = Color3.fromHSV(hue, 1, 1)
    for _, part in pairs(char:GetDescendants()) do
        if part:IsA("BasePart") or part:IsA("MeshPart") then
            if not _G.VisualConfigs.OriginalColors[part] then _G.VisualConfigs.OriginalColors[part] = part.Color end
            part.Color = rainbowColor; part.Material = Enum.Material.Neon
        elseif part:IsA("CharacterMesh") or part:IsA("Clothing") or part:IsA("ShirtGraphic") then part.Enabled = false end
    end
end

